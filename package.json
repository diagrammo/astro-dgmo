{
  "name": "astro-dgmo",
  "version": "0.2.0",
  "description": "Astro integration to render DGMO diagrams from fenced code blocks at build time. Powered by @diagrammo/dgmo.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/astro-dgmo.git"
  },
  "homepage": "https://github.com/diagrammo/astro-dgmo#readme",
  "bugs": {
    "url": "https://github.com/diagrammo/astro-dgmo/issues"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "withastro",
    "dgmo",
    "diagrammo",
    "diagram",
    "diagrams",
    "mdx",
    "markdown",
    "remark"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./remark": {
      "types": "./dist/remark.d.ts",
      "import": "./dist/remark.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@diagrammo/dgmo": ">=0.8.25",
    "astro": ">=4.0.0"
  },
  "dependencies": {
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@diagrammo/dgmo": "^0.8.26",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "astro": "^6.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
